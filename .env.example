# Kalshi MCP Server — environment configuration
#
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` — it is gitignored.
#
# Get an API key:   https://kalshi.com/account/profile  (Profile -> API Keys)
# Demo signup:      https://demo.kalshi.co/account/profile
# Auth docs:        https://docs.kalshi.com/getting_started/api_keys


# ─── Required ─────────────────────────────────────────────────────────────

# The Key ID shown in the Kalshi UI when you generated the key pair.
KALSHI_API_KEY_ID=

# Provide the RSA private key EITHER as a path OR inline as PEM contents.
# - PATH is the common case for local development.
# - PEM is for hosted deployments where you set an env var (no filesystem).
KALSHI_PRIVATE_KEY_PATH=/absolute/path/to/kalshi_private_key.pem
# KALSHI_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# Which Kalshi environment to talk to: `demo` or `prod`.
# Demo and prod use SEPARATE key pairs — you cannot share a key between them.
KALSHI_ENV=demo


# ─── Safety guards (highly recommended) ──────────────────────────────────

# To talk to production at all, you MUST set this to "1". This is a
# deliberate footgun-prevention measure — the server refuses to start with
# KALSHI_ENV=prod unless this is explicitly set.
KALSHI_ALLOW_PROD=0

# Read-only by default. Order placement / cancellation / amendment tools
# refuse to operate unless this is set to "1".
KALSHI_TRADING_ENABLED=0


# ─── Optional safety controls ─────────────────────────────────────────────
#
# These four values are the HARD CEILING. The kalshi_set_safety_limits tool
# can tighten any of them at runtime (no redeploy) but can never loosen past
# the value set here. Runtime overrides persist if MCP_REDIS_URL is set
# (below); otherwise they reset to these ceilings on restart.

# Max cost in USD of a single order (refused above this). Default: 25.
# MCP_MAX_ORDER_SIZE_USD=25

# Max total order COST in USD per UTC day (refused above this). Default: 250.
# MCP_DAILY_LIMIT_USD=250

# Max contracts per single order. Default: 100.
# MCP_MAX_CONTRACTS_PER_ORDER=100

# Minimum cash balance the server will refuse to spend below. Default: 0.
# MCP_CASH_RESERVE_USD=0

# Whether the kalshi_set_safety_limits operator tool is available (lets you
# TIGHTEN the four limits at runtime, never loosen past the ceilings above).
# Default: 1 (enabled). Set to 0 to drop the tool entirely — useful on a
# shared HTTP deploy where allowlisted users shouldn't re-tune the safety
# envelope; limits then change only via these env vars + redeploy.
# MCP_ALLOW_RUNTIME_LIMIT_TUNING=1


# ─── Optional transport / runtime ─────────────────────────────────────────

# stdio (default) or http
# MCP_TRANSPORT=stdio

# Port when running as http transport. Default: 8000.
# PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR. Default: INFO.
# LOG_LEVEL=INFO


# ─── Remote MCP / OAuth (only when MCP_TRANSPORT=http) ────────────────────
#
# These are ONLY needed if you're exposing this server over HTTP for
# remote MCP clients (e.g. claude.ai custom connector). For local stdio
# use, ignore everything below this line.
#
# If HTTP transport is used WITHOUT these set, the server refuses to
# start — anyone reaching the port could otherwise call your trade tools.
# Override that refusal with MCP_ALLOW_INSECURE_HTTP=1 for local-only
# dev testing (DO NOT use that flag for any non-localhost deployment).

# GitHub OAuth App credentials. Create one at:
#   https://github.com/settings/developers -> New OAuth App
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Public URL the server is reachable at (no trailing slash). Used as the
# OAuth callback base + as the "issuer" the proxy advertises.
# MCP_BASE_URL=https://kalshi-mcp-XXXXXX.onrender.com

# Comma-separated GitHub logins permitted to call tools. The OAuth proxy
# will let any GitHub user authenticate, but this middleware rejects tool
# calls from logins not in this list.
# MCP_ALLOWED_GITHUB_LOGINS=your-github-login

# Stable signing key for proxy-issued JWTs (64+ bytes of URL-safe base64).
# Generate once with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Without this, a fresh key is generated each start and previously-issued
# tokens become invalid on restart (claude.ai users would reconnect).
# MCP_JWT_SIGNING_KEY=

# Upstash Redis URL — does double duty: (1) persistent DCR client storage
# for the OAuth proxy (without it, client registrations live only in
# container memory and a redeploy forces every client to reconnect), and
# (2) persistence for runtime safety-limit overrides set via
# kalshi_set_safety_limits (without it, overrides reset to the env ceilings
# on restart). Free Upstash tier is sufficient. Note: use `rediss://` (TLS).
# MCP_REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# Override: allow HTTP transport without OAuth. ONLY for local dev.
# MCP_ALLOW_INSECURE_HTTP=0
